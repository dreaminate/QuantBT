{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuantBT",
  "version": "1.0.0",
  "identifier": "com.quantbt.desktop",
  "build": {
    "frontendDist": "../../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "beforeBuildCommand": "cd ../frontend && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "QuantBT · Agent 工作台",
        "label": "main",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "backgroundColor": "#0d1117",
        "titleBarStyle": "Visible",
        "url": "index.html?view=agent-workbench"
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob: http://127.0.0.1:* http://localhost:* https://api.binance.com https://fapi.binance.com https://testnet.binance.vision https://testnet.binancefuture.com https://api.anthropic.com https://api.openai.com https://*.alicloudapi.com",
      "freezePrototype": true
    },
    "macOSPrivateApi": false
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Finance",
    "shortDescription": "QuantBT 量化研究工坊",
    "longDescription": "QuantBT 桌面端 - 全栈量化平台：聚宽风研究 + Mode 2 教学型 agent + Binance 实盘安全阶梯。API key 仅存本地 keyring，永远不离开你的机器。",
    "copyright": "© 2026 QuantBT Team",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "exceptionDomain": "",
      "frameworks": [],
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    },
    "windows": {
      "wix": {},
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine"
      }
    },
    "linux": {
      "deb": { "depends": [] },
      "appimage": { "bundleMediaFramework": false }
    }
  }
}
