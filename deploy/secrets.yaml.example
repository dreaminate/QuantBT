# QuantBT · ~/.quantbt/secrets.yaml 模板
#
# 把本文件拷到 ~/.quantbt/secrets.yaml 并 chmod 600，
# 按需要填入字段（全部可选；空字段自动 fallback 到 stub / DevLocalLLM）。
#
# 你也可以在 UI 工坊 → 系统设置直接填表单，前端会写回这里。

tushare:
  token: ""

llm:
  # 每个 provider 都接收 api_key + base_url + model；base_url 留空走默认。
  # 优先级：anthropic > openai > qwen > custom
  anthropic:
    api_key: ""
    base_url: ""        # 默认 https://api.anthropic.com/v1
    model: ""           # 默认 claude-sonnet-4-5
  openai:
    api_key: ""
    base_url: ""        # 默认 https://api.openai.com/v1
    model: ""           # 默认 gpt-4o
  qwen:
    api_key: ""
    base_url: ""        # 默认 https://dashscope.aliyuncs.com/compatible-mode/v1
    model: ""           # 默认 qwen-max
  custom:
    # 任意 OpenAI 兼容端点（ollama / vLLM / 私有代理 / 国产 LLM 等）
    api_key: ""
    base_url: ""        # 必填，例 http://localhost:11434/v1
    model: ""           # 必填，例 qwen2.5:32b

binance:
  testnet:
    api_key: ""
    api_secret: ""
  mainnet:
    api_key: ""
    api_secret: ""

sentry:
  dsn: ""
